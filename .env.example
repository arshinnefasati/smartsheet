# Copy this file to .env and fill in your keys

# Smartsheet API key
SMARTSHEET_API_KEY=your_smartsheet_api_key_here

# Sheet ID from the Smartsheet URL
SMARTSHEET_SHEET_ID=your_sheet_id_here

# Full project name (overrides sheet name)
PROJECT_NAME=

# Anthropic API key (leave blank for rule-based text)
ANTHROPIC_API_KEY=

# Paths — point to your template files
SOURCE_PPTX=/path/to/your/template.pptx
SOURCE_XLSX=/path/to/your/timeline_extract.xlsx
